{
  "env": {
    "ENABLE_LSP_TOOL": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "includeCoAuthoredBy": false,
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(chmod +x /Users/stefan/work/dev-environment/switch-toolchain.py)",
      "Bash(python3 switch-toolchain.py --list)",
      "Bash(python3 switch-toolchain.py --current)",
      "Bash(python3 switch-toolchain.py go)",
      "Bash(python3 switch-toolchain.py cs)",
      "Bash(python3 switch-toolchain.py python)",
      "Bash(gh api:*)",
      "Bash(docker info:*)",
      "Bash(docker build:*)",
      "Bash(git:*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "/workspace/.claude/statusline.sh"
  },
  "spinnerTipsEnabled": false,
  "plansDirectory": "docs/plans",
  "prefersReducedMotion": true,
  "showThinkingSummaries": true
}